{
  "name": "fluent-styles",
  "description": "Develop different styled versions of UI components.",
  "version": "1.62.1",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "types": "lib/typescript/index.d.ts",
  "files": [
    "lib/",
    "src/",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/**.md"
  ],
  "keywords": [
    "react-native",
    "ui-components",
    "typescript",
    "fluent-styles"
  ],
  "license": "Apache-2.0",
  "homepage": "https://github.com/suftnetrepo/fluent-styles-next#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/suftnetrepo/fluent-styles-next.git"
  },
  "bugs": {
    "url": "https://github.com/suftnetrepo/fluent-styles-next/issues"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "test": "jest --forceExit",
    "test:coverage": "jest --coverage",
    "test:clear": "jest --clearCache",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:ts": "tsc --noEmit && eslint src --ext .ts,.tsx",
    "prettier": "prettier --write '{src,demo,docs}/**/*.{js,json,yml,yaml,ts,tsx,md}'",
    "lint-staged": "lint-staged --allow-empty",
    "doc": "dumi dev",
    "doc:build": "dumi build",
    "doc:github-build": "cross-env PUBLIC_PATH=fluent-styles-next/ dumi build",
    "prepare": "husky install",
    "build": "bob build",
    "watch": "bob build --watch",
    "release": "release-it",
    "release:beta": "release-it --preRelease=beta",
    "release:major": "release-it major",
    "release:minor": "release-it minor",
    "release:patch": "release-it patch"
  },
"dependencies": {
  "react-native-popover-view": "^6.1.0"
},
"peerDependencies": {
  "react": ">=18",
  "react-native": ">=0.74",
  "react-native-safe-area-context": ">=4",
  "react-native-svg": ">=13",
  "react-native-vector-icons": ">=10"
},
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@react-native/babel-preset": "0.74.85",
    "@release-it/conventional-changelog": "^10.0.1",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "13.2.0",
    "@types/jest": "^29.5.14",
    "@types/react-is": "^19.0.0",
    "@types/react-test-renderer": "^19.1.0",
    "@types/react-native-vector-icons": "^6.4.18",
    "babel-jest": "^29.7.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.1",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^15.5.1",
    "prettier": "~3.2.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.4",
    "react-test-renderer": "19.1.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "react-native-builder-bob": "0.30.2",
    "react-native-safe-area-context": "5.4.0",
    "react-native-svg": "15.4.0",
    "react-native-vector-icons": "^10.2.0",
    "react-native-web": "^0.20.0",
    "release-it": "^19.0.2",
    "ts-jest": "^29.3.2",
    "typescript": "~5.3.3"
  },
"overrides": {
  "react": "19.1.0",
  "react-dom": "19.1.0",
  "@types/react": "^19.1.0",
  "prettier": "~3.2.0"
},
  "prettier": "@fruits-chain/prettier-config-preset",
  "lint-staged": {
    "*.{yml,yaml,md}": [
      "prettier --write"
    ],
    "*.{js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,jsx,ts,tsx}": [
      "bash -c tsc --noEmit",
      "eslint --fix",
      "prettier --write"
    ]
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "commonjs",
        {
          "esm": true
        }
      ],
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ],
    "exclude": [
      "**/{__tests__,__fixtures__,__mocks__}/**",
      "**/**.md"
    ]
  },
  "release-it": {
    "git": {
      "commitMessage": "chore: release ${version}",
      "tagName": "v${version}"
    },
    "github": {
      "release": true
    },
    "npm": {
      "publish": false
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": "angular",
        "infile": false,
        "ignoreRecommendedBump": true
      }
    }
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  }
}